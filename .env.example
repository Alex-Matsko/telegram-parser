# ========================
# Database
# ========================
POSTGRES_DB=price_aggregator
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# ========================
# Telegram
# ========================
# Получите API ID и Hash на https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session string (генерируется при первом запуске)
TELEGRAM_SESSION_STRING=

# ========================
# LLM для парсинга сложных сообщений
# ========================
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ========================
# Security
# ========================
SECRET_KEY=generate-a-strong-random-key-here

# ========================
# Frontend
# ========================
# Включить моковые данные (true для демо без backend)
VITE_USE_MOCKS=false
VITE_API_BASE_URL=/api
